{
  "name": "@cancelkit/react",
  "version": "0.1.0",
  "description": "React SDK for CancelKit — embed cancel flows in your React app",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js && tsc --declaration --emitDeclarationOnly --declarationDir dist",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "rollup": "^4.13.0",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "cancelkit",
    "cancel-flow",
    "churn",
    "stripe",
    "react"
  ],
  "license": "MIT"
}
